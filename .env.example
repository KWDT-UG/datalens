DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
DJANGO_SECURE_SSL_REDIRECT=false
DATALENS_AUTH_COOKIE_NAME=datalens_auth
DATALENS_AUTH_COOKIE_MAX_AGE=28800
DATALENS_AUTH_COOKIE_SECURE=false
DATALENS_AUTH_COOKIE_SAMESITE=Lax
DATALENS_ALLOW_ANONYMOUS_API=false
# Local-only credentials created by `make seed-demo-data`.
DATALENS_LOCAL_ADMIN_USERNAME=admin
DATALENS_LOCAL_ADMIN_PASSWORD=adm!n@pass123
DATALENS_LOCAL_ADMIN_EMAIL=admin@example.test
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@datalens.local
# Mailtrap API is optional. With no key, Django's console backend is used.
# Local: set MAILTRAP_USE_SANDBOX=true and provide a Mailtrap sandbox inbox ID.
# Production: set MAILTRAP_USE_SANDBOX=false and use a verified sender address.
MAILTRAP_API_KEY=
MAILTRAP_USE_SANDBOX=false
MAILTRAP_INBOX_ID=
FRONTEND_APP_URL=http://localhost:5173
DRF_ANON_THROTTLE_RATE=1000/hour
DRF_USER_THROTTLE_RATE=5000/hour
DRF_AUTH_THROTTLE_RATE=20/minute

POSTGRES_DB=datalens
POSTGRES_USER=datalens
POSTGRES_PASSWORD=datalens
POSTGRES_HOST=db
POSTGRES_PORT=5432

VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://backend:8000
BACKEND_UPSTREAM=http://backend:8000
